# =====================================================================
# DIAMOR Phase 1A — example environment. Copy to your secret store / .env and fill in.
# Your existing Django `default` DB is configured ELSEWHERE and is NOT changed here.
# Never commit real passwords. Prefer your platform's secret manager.
# =====================================================================

# --- diamor_app: Django-managed app DB (holds ONLY diamor_staff_identity_map) ---
DIAMOR_APP_DB_NAME=diamor_app
DIAMOR_APP_DB_USER=diamor_app_user
DIAMOR_APP_DB_PASSWORD=          # set out of band (psql \password); never commit
DIAMOR_APP_DB_HOST=
DIAMOR_APP_DB_PORT=5432
DIAMOR_APP_DB_SSLMODE=require

# --- diamor: the DIAMOR database (e.g. diamor_staging), RAW SQL only, via an app role ---
# Phase 1A uses the manager app role. MUST NOT be zixan_user. MUST NOT be a superuser.
DIAMOR_DB_NAME=diamor_staging
DIAMOR_DB_USER=app_manager_admin
DIAMOR_DB_PASSWORD=              # set out of band; never commit
DIAMOR_DB_HOST=
DIAMOR_DB_PORT=5432
DIAMOR_DB_SSLMODE=require
